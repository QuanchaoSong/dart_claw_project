# =============================================================
#  darted_claw_project — monorepo root .gitignore
# =============================================================

# -------------------------------------------------------------
# Flutter / Dart / Pub
# -------------------------------------------------------------
**/doc/api/
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/.pub-cache/
**/.pub/
**/build/
**/coverage/
**/*.dart.js
**/*.dart.js.deps
**/*.dart.js.map
**/*.part.js
**/pubspec.lock          # 子包 lock 各自决定；顶层 monorepo 无 lock

# -------------------------------------------------------------
# macOS
# -------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# -------------------------------------------------------------
# Xcode / macOS runner
# -------------------------------------------------------------
**/xcuserdata/
**/Flutter/ephemeral/
**/Pods/
**/dgph
**/*.xcworkspace/xcuserdata/
**/*.xcodeproj/xcuserdata/
**/DerivedData/
**/*.moved-aside
**/*.pbxuser
!default.pbxuser
**/*.mode1v3
!default.mode1v3
**/*.mode2v3
!default.mode2v3
**/*.perspectivev3
!default.perspectivev3

# -------------------------------------------------------------
# Android
# -------------------------------------------------------------
**/android/app/debug/
**/android/app/profile/
**/android/app/release/
**/android/.gradle/
**/android/local.properties
**/android/captures/
**/android/.externalNativeBuild/
**/android/.cxx/

# -------------------------------------------------------------
# iOS
# -------------------------------------------------------------
**/ios/Flutter/.last_build_id
**/ios/Pods/
**/ios/.symlinks/

# -------------------------------------------------------------
# Linux runner
# -------------------------------------------------------------
**/linux/flutter/ephemeral/

# -------------------------------------------------------------
# Windows runner
# -------------------------------------------------------------
**/windows/flutter/ephemeral/

# -------------------------------------------------------------
# Web
# -------------------------------------------------------------
**/web/flutter_service_worker.js

# -------------------------------------------------------------
# Symbolication / Obfuscation
# -------------------------------------------------------------
app.*.symbols
app.*.map.json

# -------------------------------------------------------------
# IntelliJ / Android Studio
# -------------------------------------------------------------
*.iml
*.ipr
*.iws
.idea/
.fleet/

# -------------------------------------------------------------
# VS Code（保留 .vscode 以便共享 launch/tasks 配置；
#          如不需要共享则取消注释下面那行）
# -------------------------------------------------------------
# .vscode/

# -------------------------------------------------------------
# OS / Editor 通用
# -------------------------------------------------------------
*.class
*.log
*.pyc
*.swp
.atom/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/
Thumbs.db
ehthumbs.db

# -------------------------------------------------------------
# 本地环境 / 敏感配置（绝对不能入库）
# -------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# -------------------------------------------------------------
# 项目级本地上下文文件（仅本地可见，不入库）
# -------------------------------------------------------------
CONTEXT.md

# -------------------------------------------------------------
# 本地参考源码（clone 下来供 AI 学习，不入库）
# -------------------------------------------------------------
vscode-copilot-chat/
